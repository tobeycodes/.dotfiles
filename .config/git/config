[branch]
  sort = "-committerdate"

[commit]
  gpgSign = true

[core]
  editor = nvim
  pager = hunk pager

[fetch]
  prune = true

[gpg]
  format = ssh

[gpg "ssh"]
  program = "~/.local/bin/git-ssh-sign"

[init]
  defaultBranch = main

[merge]
  conflictStyle = zdiff3
  tool = nvimdiff

[mergetool]
  prompt = false
  keepBackup = false

[mergetool "nvimdiff"]
  layout = "LOCAL,BASE,REMOTE / MERGED"

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true

[rerere]
  enabled = true

[tag]
  gpgSign = true

[user]
  name = tobey
  email = tobey@tobey.codes
  github = tobeycodes
  signingKey = "~/.ssh/tobey.pub"

[gitbutler]
  signCommits = true

[but "ui"]
	tui = true

[includeIf "gitdir:~/code/squads-treasury/"]
  path = "~/.config/git/work_config"

[includeIf "gitdir:~/code/squads-fuse/"]
  path = "~/.config/git/work_config"
