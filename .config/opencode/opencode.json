{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "autoshare": false,
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next"
        }
      }
    }
  },
  "lsp": true,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": false
    },
    "auggie": {
      "type": "remote",
      "url": "https://api.augmentcode.com/mcp",
      "enabled": false
    },
    "uidotsh": {
      "type": "remote",
      "url": "https://ui.sh/mcp?agent=opencode",
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:UIDOTSH_TOKEN}"
      }
    },
    "codegraph": {
      "type": "local",
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true
    },
    "tablepro": {
      "type": "local",
      "command": ["/Applications/TablePro.app/Contents/MacOS/tablepro-mcp"],
      "enabled": false
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false
    },
    "posthog": {
      "type": "remote",
      "url": "https://mcp.posthog.com/mcp",
      "enabled": false
    },
    "incident": {
      "type": "remote",
      "url": "https://mcp.incident.io/mcp",
      "enabled": false
    },
    "railway": {
      "url": "https://mcp.railway.com",
      "enabled": false,
      "type": "remote"
    }
  },
  "plugin": ["@plannotator/opencode@latest"]
}
